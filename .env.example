# ===========================================
# PMS Guest House - Variables d'environnement
# ===========================================
# Copiez ce fichier en .env et remplissez les valeurs

# ===========================================
# BASE DE DONNÉES (PostgreSQL pour Vercel)
# ===========================================
# Option 1: Neon (recommandé pour Vercel)
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Option 2: Supabase
# DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"
# DIRECT_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"

# Option 3: PlanetScale
# DATABASE_URL="mysql://username:password@aws.connect.psdb.cloud/database?sslaccept=strict"
# DIRECT_URL="mysql://username:password@aws.connect.psdb.cloud/database?sslaccept=strict"

# Option 4: Railway
# DATABASE_URL="postgresql://postgres:password@containers-us-west-xxx.railway.app:5432/railway"
# DIRECT_URL="postgresql://postgres:password@containers-us-west-xxx.railway.app:5432/railway"

# ===========================================
# NEXTAUTH.JS (Authentification)
# ===========================================
# URL de production (Vercel)
NEXTAUTH_URL="https://votre-app.vercel.app"

# Secret pour JWT (générez avec: openssl rand -base64 32)
NEXTAUTH_SECRET="votre-secret-tres-securise-ici"

# ===========================================
# APPLICATION
# ===========================================
APP_NAME="PMS Guest House"
APP_URL="https://votre-app.vercel.app"

# ===========================================
# OPTIONNEL - Services externes
# ===========================================
# Stripe pour les paiements
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# SendGrid pour les emails
# SENDGRID_API_KEY="SG..."
# SENDGRID_FROM_EMAIL="noreply@votre-domaine.com"

# Twilio pour les SMS
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_PHONE_NUMBER="+33..."
